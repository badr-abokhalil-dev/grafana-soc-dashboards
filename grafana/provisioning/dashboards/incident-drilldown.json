      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# \ud83d\udd0d Incident Drilldown\nFilter by Event ID variable above, or click an incident from the Overview"
      }
    },
    {
      "id": 2,
      "title": "Incidents by Category",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 2
      },
      "datasource": {
        "uid": "mock-data",
        "type": "yesoreyeram-infinity-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "mock-data"
          },
          "type": "json",
          "source": "url",
          "url": "http://soc-mock-server:3001/incidents/by_category?start_time=${__from}&end_time=${__to}",
          "url_options": {
            "method": "GET"
          },
          "parser": "backend",
          "root_selector": "",
          "columns": [
            {
              "selector": "category",
              "text": "Category",
              "type": "string"
            },
            {
              "selector": "count",
              "text": "Count",
              "type": "number"
            }
          ]
        }
      ],
      "transformations": [],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7
