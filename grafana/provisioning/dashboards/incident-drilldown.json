                "value": {
                  "fixedColor": "dark-blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
