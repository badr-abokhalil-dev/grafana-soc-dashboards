              {
                "key": "search",
                "value": "search index=main sourcetype=soc_incident | bin _time span=1d | eval mtta=ttd_min*0.6, mttc=ttr_min*0.7 | stats avg(ttd_min) as mttd avg(ttr_min) as mttr avg(mtta) as mtta avg(mttc) as mttc by _time"
