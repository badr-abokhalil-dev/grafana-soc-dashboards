    {
      "id": 2,
      "title": "Total Alerts",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 2
      },
      "datasource": {
        "uid": "splunk-api",
        "type": "yesoreyeram-infinity-datasource"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "splunk-api"
          },
          "type": "json",
          "source": "url",
          "url": "http://soc-splunk:8089/services/search/jobs/oneshot",
          "url_options": {
            "method": "POST",
            "body_type": "x-www-form-urlencoded",
            "body_form": [
              {
                "key": "search",
                "value": "search index=main sourcetype=soc_alert | stats sum(count) as total"
              },
              {
                "key": "output_mode",
                "value": "json"
              },
              {
                "key": "earliest_time",
                "value": "${__from:date:iso}"
              },
              {
                "key": "latest_time",
                "value": "${__to:date:iso}"
              }
            ]
          },
          "parser": "backend",
          "root_selector": "results",
          "columns": [
            {
              "selector": "total",
              "text": "Total",
              "type": "number"
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "textMode": "value"
      }
    },
