# === Splunk ===
SPLUNK_PASSWORD=SocDash2026!

# === Grafana ===
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=SocDash2026!

# === Splunk API (used by Grafana Infinity) ===
# Generate a token in Splunk: Settings → Tokens → New Token
SPLUNK_API_URL=https://splunk:8089
SPLUNK_API_TOKEN=your_splunk_token_here

# === SOAR API (when ready) ===
SOAR_API_URL=https://your-soar-instance
SOAR_API_TOKEN=your_soar_token_here

# === Mode ===
# Set to "mock" to use static JSON files instead of live APIs
# Set to "live" to query Splunk/SOAR directly
DASHBOARD_MODE=mock
